<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/checkInAiRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_checkin_ai_screen"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Background glow -->
    <View
        android:id="@+id/glowCheckInTopLeft"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginStart="-40dp"
        android:layout_marginTop="-60dp"
        android:background="@drawable/bg_checkin_glow_pink"
        android:alpha="0.7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glowCheckInBottomRight"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginEnd="-50dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/bg_checkin_glow_mint"
        android:alpha="0.65"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Decor icons -->
    <ImageView
        android:id="@+id/decorCheckInFlowerTopLeft"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginStart="5dp"
        android:layout_marginTop="70dp"
        android:alpha="0.85"
        android:contentDescription="decor"
        android:src="@drawable/ic_flower_pink"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/decorCheckInFlowerTopRight"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginTop="46dp"
        android:layout_marginEnd="60dp"
        android:alpha="0.8"
        android:contentDescription="decor"
        android:src="@drawable/ic_flower_mint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/decorCheckInFlowerMiddleLeft"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="45dp"
        android:layout_marginTop="333dp"
        android:alpha="0.85"
        android:contentDescription="decor"
        android:src="@drawable/ic_flower_pink"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/decorCheckInFlowerMiddleRight"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginTop="296dp"
        android:layout_marginEnd="48dp"
        android:alpha="0.75"
        android:contentDescription="decor"
        android:src="@drawable/ic_flower_purple"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/decorCheckInFlowerBottomRight"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="150dp"
        android:alpha="0.8"
        android:contentDescription="decor"
        android:src="@drawable/ic_flower_mint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ScrollView
        android:id="@+id/scrollCheckInAi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutCheckInAiContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="780dp"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutCheckInHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingTop="54dp"
                android:paddingEnd="24dp">

                <ImageButton
                    android:id="@+id/btnBackCheckInAi"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:background="@drawable/bg_checkin_header_button"
                    android:contentDescription="Quay lại"
                    android:padding="13dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/layoutCheckInTitle"
                    android:layout_width="144dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintTop_toTopOf="@id/btnBackCheckInAi"
                    app:layout_constraintBottom_toBottomOf="@id/btnBackCheckInAi"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/txtCheckInAiLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:letterSpacing="0.12"
                        android:text="AI Cảm xúc"
                        android:textAllCaps="true"
                        android:textColor="#E86FA0"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCheckInAiTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Check-in hôm nay"
                        android:textColor="#2D3A5E"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Heami message -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutCheckInMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp">

                <ImageView
                    android:id="@+id/imgCheckInHeami"
                    android:layout_width="80dp"
                    android:layout_height="76dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Heami"
                    android:src="@drawable/ic_cloud_happy"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <LinearLayout
                    android:id="@+id/cardCheckInBubble"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_checkin_speech_bubble"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="13dp"
                    app:layout_constraintStart_toEndOf="@id/imgCheckInHeami"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/imgCheckInHeami">

                    <TextView
                        android:id="@+id/txtCheckInBubble"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="3dp"
                        android:text="Heami đang cảm nhận năng lượng&#10;của bạn hôm nay..."
                        android:textColor="#4A5A7A"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Camera preview -->
            <FrameLayout
                android:id="@+id/layoutCameraPreviewWrap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCameraPreview"
                    android:layout_width="260dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center_horizontal"
                    android:elevation="2dp"
                    app:cardCornerRadius="34dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:id="@+id/layoutCameraInner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_checkin_camera_card"
                        android:clipChildren="true"
                        android:clipToPadding="true">

                        <androidx.camera.view.PreviewView
                            android:id="@+id/previewCheckInCamera"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            app:scaleType="fillCenter" />

                        <View
                            android:id="@+id/viewCameraPreviewPattern"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.18"
                            android:background="@drawable/bg_checkin_camera_pattern" />

                        <ImageView
                            android:id="@+id/imgCheckInCameraPreview"
                            android:layout_width="280dp"
                            android:layout_height="300dp"
                            android:layout_gravity="center"
                            android:adjustViewBounds="true"
                            android:alpha="0.3"
                            android:contentDescription="camera preview"
                            android:scaleType="fitCenter"
                            android:src="@drawable/img_checkin_ai_camera" />

                        <View
                            android:id="@+id/viewCheckInScanGlow"
                            android:layout_width="210dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:alpha="0.65"
                            android:background="@drawable/bg_checkin_scan_glow" />

                        <View
                            android:id="@+id/viewCheckInScanLine"
                            android:layout_width="218dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:alpha="0.85"
                            android:background="@drawable/bg_checkin_scan_line" />

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Instruction -->
            <TextView
                android:id="@+id/txtCheckInInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:text="Giữ yên khuôn mặt trong khung hình và&#10; nhìn thẳng vào camera nhé"
                android:textColor="#F291A3"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

            <!-- Manual mood button -->
            <LinearLayout
                android:id="@+id/btnManualMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:background="@drawable/bg_checkin_manual_button"
                android:gravity="center"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/imgManualMoodIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="manual mood"
                    android:src="@drawable/ic_checkin_manual_mood" />

                <TextView
                    android:id="@+id/txtManualMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Chọn cảm xúc thủ công"
                    android:textColor="#E86FA0"
                    android:textSize="15.5sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtManualMoodHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:gravity="center"
                android:text="Camera không hoạt động? Bạn có thể tự chọn cảm xúc"
                android:textColor="#C0B8CC"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>