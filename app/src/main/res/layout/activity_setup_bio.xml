<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FD"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#2D3142"
            tools:ignore="ContentDescription,TouchTargetSizeCheck,SpeakableTextPresentCheck" />
        <LinearLayout
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <View android:layout_width="30dp" android:layout_height="4dp" android:layout_margin="2dp" android:background="#E86FA0" />
                <View android:layout_width="30dp" android:layout_height="4dp" android:layout_margin="2dp" android:background="#E86FA0" />
                <View android:layout_width="30dp" android:layout_height="4dp" android:layout_margin="2dp" android:background="#E0E0E0" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bước 2 / 3"
                android:textColor="#C0BACA"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:textStyle="bold"
                tools:ignore="HardcodedText,SmallSp" />
        </LinearLayout>
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Giới thiệu bản thân"
        android:textColor="#2D3142"
        android:textSize="22sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

    <androidx.cardview.widget.CardView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#FFEBF2"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false" >
        <TextView
            android:id="@+id/tvPreviewAvatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🌸"
            android:textSize="40sp"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            tools:ignore="HardcodedText" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NICKNAME"
                android:textColor="#C0BACA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                tools:ignore="HardcodedText" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_pink_selector"
                android:addStatesFromChildren="true"
                android:paddingHorizontal="15dp">

                <EditText
                    android:id="@+id/etNickname"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/tvNicknameCount"
                    android:background="@null"
                    android:hint="Heami nên gọi bạn là gì?"
                    android:inputType="textPersonName"
                    android:maxLength="20"
                    android:textColor="#2D3142"
                    android:textSize="15sp"
                    tools:ignore="Autofill,HardcodedText" />

                <TextView
                    android:id="@+id/tvNicknameCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="0/20"
                    android:textColor="#C0BACA"
                    android:textSize="11sp"
                    tools:ignore="HardcodedText" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Tối thiểu 2 ký tự · Đây là tên riêng tư của bạn"
                android:textColor="#C0BACA"
                android:textSize="10sp"
                tools:ignore="HardcodedText,SmallSp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHÂM NGÔN (TUỲ CHỌN)"
                android:textColor="#C0BACA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_pink_selector"
                android:addStatesFromChildren="true"
                android:orientation="vertical"
                android:padding="12dp">

                <EditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="top"
                    android:background="@null"
                    android:hint="Câu nói truyền cảm hứng mà bạn yêu thích..."
                    android:inputType="textMultiLine"
                    android:maxLength="60"
                    android:textColor="#2D3142"
                    android:textSize="14sp"
                    tools:ignore="Autofill,HardcodedText" />

                <TextView
                    android:id="@+id/tvBioCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="0/60"
                    android:textColor="#C0BACA"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNextStep2"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Tiếp theo"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="18sp"
        android:backgroundTint="#E86FA0"
        app:cornerRadius="30dp"
        android:elevation="4dp"/>

</LinearLayout>