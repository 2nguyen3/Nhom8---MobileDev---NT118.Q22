<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutBottomNav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="10dp"
    android:alpha="0.98"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="18dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingTop="10dp"
    android:paddingEnd="6dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="7dp"
        android:paddingEnd="4dp"
        android:paddingBottom="7dp">

        <ImageView
            android:id="@+id/navHomeIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="home"
            android:src="@drawable/ic_nav_home" />

        <TextView
            android:id="@+id/navHomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Trang chủ"
            android:textColor="#B5BFD1"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navTherapy"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="7dp"
        android:paddingEnd="4dp"
        android:paddingBottom="7dp">

        <ImageView
            android:id="@+id/navTherapyIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="therapy"
            android:src="@drawable/ic_nav_therapy" />

        <TextView
            android:id="@+id/navTherapyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Trị liệu"
            android:textColor="#B5BFD1"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navCommunity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="7dp"
        android:paddingEnd="4dp"
        android:paddingBottom="7dp">

        <ImageView
            android:id="@+id/navCommunityIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="community"
            android:src="@drawable/ic_nav_community" />

        <TextView
            android:id="@+id/navCommunityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:text="Cộng&#10;đồng"
            android:textColor="#B5BFD1"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navDoctor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="7dp"
        android:paddingEnd="4dp"
        android:paddingBottom="7dp">

        <ImageView
            android:id="@+id/navDoctorIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="doctor"
            android:src="@drawable/ic_nav_doctor" />

        <TextView
            android:id="@+id/navDoctorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Bác sĩ"
            android:textColor="#B5BFD1"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="7dp"
        android:paddingEnd="4dp"
        android:paddingBottom="7dp">

        <ImageView
            android:id="@+id/navProfileIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="profile"
            android:src="@drawable/ic_nav_profile" />

        <TextView
            android:id="@+id/navProfileText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Cá nhân"
            android:textColor="#B5BFD1"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>