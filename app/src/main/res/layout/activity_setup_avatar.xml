<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FD"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <View android:layout_width="30dp" android:layout_height="4dp" android:layout_margin="2dp" android:background="#E86FA0" />
                <View android:layout_width="30dp" android:layout_height="4dp" android:layout_margin="2dp" android:background="#E0E0E0" />
                <View android:layout_width="30dp" android:layout_height="4dp" android:layout_margin="2dp" android:background="#E0E0E0" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bước 1 / 3"
                android:textColor="#C0BACA"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:textStyle="bold"
                tools:ignore="SmallSp" />
        </LinearLayout>
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Chọn avatar phù hợp"
        android:textColor="#2D3142"
        android:textSize="22sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center"
        android:layout_marginTop="30dp">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="70dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FEE4F0"
            app:cardPreventCornerOverlap="false" >
            <TextView
                android:id="@+id/tvSelectedAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🌸"
                android:textSize="80sp"
                android:includeFontPadding="false"
                android:paddingBottom="8dp" />
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="2dp">
        <GridLayout
            android:id="@+id/gridAvatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:padding="15dp"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🌸" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🌻" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🌷" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🍀" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🦄" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🐻" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🦊" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:textSize="30sp"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="🦁" />
        </GridLayout>
    </androidx.cardview.widget.CardView>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNextStep1"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Tiếp theo"
        android:textAllCaps="false"
        android:backgroundTint="#E86FA0"
        app:cornerRadius="30dp"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
