<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mm_bg_soft"
    android:padding="18dp">

    <!-- top chip -->
    <TextView
        android:id="@+id/chipDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/mm_chip"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:text="@string/today"
        android:textColor="@color/mm_text"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- close X -->
    <TextView
        android:id="@+id/btnClose"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/mm_chip"
        android:gravity="center"
        android:text="@string/close"
        android:textColor="@color/mm_text"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="@string/title_mood"
        android:textColor="@color/mm_text"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/chipDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/subtitle_mood"
        android:textColor="@color/mm_text_60"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- guideline to pin mood strip near center like reference -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gMoodCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.58"/>

    <!-- Mood strip pinned to guideline (center-ish) -->
    <FrameLayout
        android:id="@+id/moodArea"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:translationY="-36dp"
        app:layout_constraintTop_toTopOf="@id/gMoodCenter"
        app:layout_constraintBottom_toBottomOf="@id/gMoodCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- waves -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/mm_wave_back"
            android:contentDescription="@null" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/mm_wave_front"
            android:contentDescription="@null" />

        <!-- overlay: place emojis exactly -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="374dp"
            android:layout_height="258dp"
            android:layout_gravity="bottom"
            tools:layout_editor_absoluteX="1dp"
            tools:layout_editor_absoluteY="1dp">

            <!-- better positions (less edge-hugging) -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/gLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.1" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/gCenter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/gRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.9" />

            <TextView
                android:id="@+id/emoSad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="8dp"
                android:text="@string/emoji_sad"
                android:textSize="32sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/gLeft"
                app:layout_constraintHorizontal_bias="0.375"
                app:layout_constraintStart_toStartOf="@id/gLeft" />

            <TextView
                android:id="@+id/emoStress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="8dp"
                android:text="@string/emoji_stress"
                android:textSize="32sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/gRight"
                app:layout_constraintHorizontal_bias="0.625"
                app:layout_constraintStart_toStartOf="@id/gRight" />

            <FrameLayout
                android:id="@+id/centerGlow"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginBottom="34dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/gCenter"
                app:layout_constraintStart_toStartOf="@id/gCenter">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/mm_glow_yellow" />

                <TextView
                    android:id="@+id/emoHappy"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/emoji_happy"
                    android:textSize="40sp" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

    <!-- label -->
    <TextView
        android:id="@+id/tvMoodLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mood_happy"
        android:textColor="@color/mm_text"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/moodArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"/>

    <!-- Bottom pill -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="@string/stop_music"
        android:textAllCaps="false"
        android:textColor="@color/mm_white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        app:elevation="10dp"
        app:backgroundTint="@color/mm_purple"
        android:background="@drawable/mm_primary_button"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginBottom="18dp"
        android:layout_marginHorizontal="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- hidden required IDs (for TV2/TV3) -->
    <LinearLayout
        android:id="@+id/hiddenButtons"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View android:id="@+id/btnHappy" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/btnSad" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/btnStress" android:layout_width="0dp" android:layout_height="0dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>