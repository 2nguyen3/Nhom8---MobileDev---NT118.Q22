<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutBookingRoot"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    android:background="@drawable/bg_mood_match_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <FrameLayout
        android:id="@+id/handleBarContainer"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginBottom="8dp">
        <View
            android:id="@+id/viewHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="#E2E8F0"
            android:backgroundTint="#D1D5DB" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollBookingContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtDialogBookingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn lịch hẹn"
                android:textColor="#2D1B47"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn ngày và giờ phù hợp với bạn"
                android:textColor="#9E8AAA"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Chọn ngày"
                android:textColor="#2D1B47"
                android:textSize="16sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="125dp"
                android:layout_marginTop="12dp"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:clipChildren="false">

                <!-- Container này sẽ được add item dynamic từ Java -->
                <LinearLayout
                    android:id="@+id/layoutDateContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:clipToPadding="false"
                    android:clipChildren="false">
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Chọn giờ"
                android:textColor="#2D1B47"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/flexTimeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:flexWrap="wrap"
                app:justifyContent="flex_start">
                <!-- Tạm thời để demo hoặc trống chờ doctor config -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vui lòng chọn ngày để xem giờ trống"
                    android:textColor="#9E8AAA"
                    android:layout_margin="8dp" />
            </com.google.android.flexbox.FlexboxLayout>

            <!-- Ghi chú trạng thái -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#FFB6D9"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã chọn"
                    android:textColor="#9E8AAA"
                    android:textSize="12sp"
                    android:fontFamily="@font/quicksand_bold" />
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#E2E8F0"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã đặt"
                    android:textColor="#9E8AAA"
                    android:textSize="12sp"
                    android:fontFamily="@font/quicksand_bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelBooking"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textColor="#94A3B8"
            android:fontFamily="@font/quicksand_bold"
            app:cornerRadius="28dp"
            app:strokeColor="#E2E8F0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmBooking"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1.5"
            android:backgroundTint="#4CAF50"
            android:enabled="false"
            android:text="Xác nhận"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/quicksand_bold"
            app:cornerRadius="28dp"
            app:elevation="0dp" />
    </LinearLayout>
</LinearLayout>