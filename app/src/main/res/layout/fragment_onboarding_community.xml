<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5EE"
    android:padding="24dp">

    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_white_rounded_button"
        android:fontFamily="@font/quicksand_bold"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:text="Bỏ qua"
        android:textColor="#313866"
        android:textSize="14sp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layout_center_community"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/tvTitleCommunity"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.3"
        app:layout_constraintVertical_chainStyle="packed">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="40sp"
            android:layout_marginBottom="-20dp"
            android:elevation="2dp" />

        <ImageView
            android:id="@+id/ivOnboardingCommunity"
            android:layout_width="220dp"
            android:layout_height="200dp"
            android:src="@drawable/ic_cloud_happy" /> <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_btn_onboarding"
        android:backgroundTint="#FFE4D1"
        android:fontFamily="@font/quicksand_bold"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="CỘNG ĐỒNG"
        android:textColor="#FF9E5E"
        android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTitleCommunity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/quicksand_bold"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:text="Cộng đồng ẩn danh \n&amp; chuyên gia tâm lý"
        android:textColor="#313866"
        android:textSize="28sp"
        app:layout_constraintBottom_toTopOf="@+id/tvDescriptionCommunity"
        app:layout_constraintTop_toBottomOf="@+id/layout_center_community" />

    <TextView
        android:id="@+id/tvDescriptionCommunity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="30dp"
        android:fontFamily="@font/quicksand_medium"
        android:gravity="center"
        android:text="Chia sẻ ẩn danh với người có tâm trạng tương tự, hoặc kết nối 1-1 với bác sĩ tâm lý chuyên nghiệp."
        android:textColor="#7D8BB7"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/layout_indicators_community"
        app:layout_constraintTop_toBottomOf="@+id/tvTitleCommunity" />

    <LinearLayout
        android:id="@+id/layout_indicators_community"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btnStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <View android:layout_width="6dp" android:layout_height="6dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_btn_onboarding" android:backgroundTint="#E0E0E0" />
        <View android:layout_width="6dp" android:layout_height="6dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_btn_onboarding" android:backgroundTint="#E0E0E0" />
        <View android:layout_width="6dp" android:layout_height="6dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_btn_onboarding" android:backgroundTint="#E0E0E0" />
        <View android:layout_width="24dp" android:layout_height="6dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_btn_onboarding" android:backgroundTint="#FF9E5E" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnBackCommunity"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_white_rounded_button"
        android:padding="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:tint="#313866"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_btn_onboarding"
        android:backgroundTint="#FF9E5E"
        android:fontFamily="@font/quicksand_bold"
        android:gravity="center"
        android:text="Bắt đầu hành trình 🌸"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@id/btnBackCommunity"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackCommunity"
        app:layout_constraintTop_toTopOf="@id/btnBackCommunity" />

</androidx.constraintlayout.widget.ConstraintLayout>