<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/communityChatListRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_community_chat_list_screen">

    <ScrollView
        android:id="@+id/scrollCommunityChatList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutCommunityChatListContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="780dp"
            android:orientation="vertical"
            android:paddingBottom="36dp">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/layoutCommunityChatHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="56dp"
                android:paddingEnd="20dp">

                <LinearLayout
                    android:id="@+id/layoutCommunityChatTitleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnBackCommunityChatList"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_community_chat_header_icon"
                        android:contentDescription="Quay lại"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_back" />

                    <TextView
                        android:id="@+id/txtCommunityChatListTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Tin nhắn ẩn danh"
                        android:textColor="#2D1B47"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Search box -->
                <LinearLayout
                    android:id="@+id/layoutCommunityChatSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_community_chat_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:id="@+id/imgCommunityChatSearch"
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:contentDescription="Tìm kiếm"
                        android:src="@drawable/ic_community_chat_search" />

                    <TextView
                        android:id="@+id/txtCommunityChatSearchHint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="Tìm kiếm tin nhắn..."
                        android:textColor="#804A3959"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Tabs -->
                <LinearLayout
                    android:id="@+id/layoutCommunityChatTabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tabCommunityChatAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_community_chat_tab_active"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:text="Tất cả  (4)"
                        android:textColor="#E8507A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tabCommunityChatUnread"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_community_chat_tab"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:text="Chưa đọc  (2)"
                        android:textColor="#B0A0C0"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Chat list -->
            <LinearLayout
                android:id="@+id/layoutCommunityChatItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Chat item 1 -->
                <LinearLayout
                    android:id="@+id/itemChatFox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_community_chat_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <View
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_community_chat_avatar_ring_blue" />

                        <TextView
                            android:id="@+id/avatarChatFox"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_community_chat_avatar_blue"
                            android:gravity="center"
                            android:text="🦊"
                            android:textSize="28sp" />

                        <View
                            android:layout_width="17dp"
                            android:layout_height="17dp"
                            android:layout_gravity="bottom|end"
                            android:layout_marginEnd="3dp"
                            android:layout_marginBottom="3dp"
                            android:background="@drawable/bg_community_chat_online_dot" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtChatFoxName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cáo nhỏ hồng"
                                android:textColor="#2D1B47"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtChatFoxTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 phút trước"
                                android:textColor="#E8507A"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtChatFoxLastMessage"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="Cảm ơn bạn đã lắng nghe mình 🌸"
                                android:textColor="#4A3A5A"
                                android:textSize="13.5sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/badgeChatFoxUnread"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_community_chat_unread_badge"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:text="2"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/dividerChatFox"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="88dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/bg_community_chat_divider" />

                <!-- Chat item 2 -->
                <LinearLayout
                    android:id="@+id/itemChatBear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_community_chat_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp">

                        <TextView
                            android:id="@+id/avatarChatBear"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_community_chat_avatar_orange"
                            android:gravity="center"
                            android:text="🐻"
                            android:textSize="28sp" />

                        <View
                            android:layout_width="17dp"
                            android:layout_height="17dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/bg_community_chat_online_dot" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtChatBearName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Gấu bông trắng"
                                android:textColor="#2D1B47"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtChatBearTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1 giờ trước"
                                android:textColor="#B0A0C0"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtChatBearLastMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="Hôm nay mình cảm thấy tốt hơn nhiều rồi!"
                            android:textColor="#9A8AAA"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/dividerChatBear"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="88dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/bg_community_chat_divider" />

                <!-- Chat item 3 -->
                <LinearLayout
                    android:id="@+id/itemChatButterfly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_community_chat_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <View
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_community_chat_avatar_ring_purple" />

                        <TextView
                            android:id="@+id/avatarChatButterfly"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_community_chat_avatar_purple"
                            android:gravity="center"
                            android:text="🦋"
                            android:textSize="28sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtChatButterflyName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Bướm tím mộng"
                                android:textColor="#2D1B47"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtChatButterflyTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3 giờ trước"
                                android:textColor="#E8507A"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtChatButterflyLastMessage"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="Mình cũng đang trong tình trạng tương..."
                                android:textColor="#4A3A5A"
                                android:textSize="13.5sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/badgeChatButterflyUnread"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_community_chat_unread_badge"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/dividerChatButterfly"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="88dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/bg_community_chat_divider" />

                <!-- Chat item 4 -->
                <LinearLayout
                    android:id="@+id/itemChatCherry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_community_chat_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp">

                        <TextView
                            android:id="@+id/avatarChatCherry"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_community_chat_avatar_blue"
                            android:gravity="center"
                            android:text="🌸"
                            android:textSize="28sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/txtChatCherryName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Hoa anh đào"
                                android:textColor="#2D1B47"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtChatCherryTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hôm qua"
                                android:textColor="#B0A0C0"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtChatCherryLastMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="Rất vui được nói chuyện với bạn"
                            android:textColor="#9A8AAA"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
                <View
                    android:id="@+id/dividerChatFlower"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="88dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/bg_community_chat_divider" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>