<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/quicksand_bold"
                    android:text="Chỉnh sửa hồ sơ"
                    android:textColor="#313866"
                    android:textSize="20sp" />

                <ImageView
                    android:id="@+id/btnDismiss"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:src="@drawable/ic_close"
                    app:tint="#C0BACA"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/layoutEditAvatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivEditAvatarBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FEE4F0"
                    android:padding="2dp"
                    app:shapeAppearanceOverlay="@style/CircleAppearance"
                    app:strokeColor="#FEE4F0"
                    app:strokeWidth="2dp" />

                <TextView
                    android:id="@+id/tvEditAvatarEmoji"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingBottom="4dp"
                    android:textColor="#FF000000"
                    android:layerType="software"
                    android:textSize="50sp"
                    tools:text="🌸" />

                <androidx.cardview.widget.CardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="2dp"
                    app:cardBackgroundColor="#E86FA0"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_edit_pen"
                        app:tint="@color/white"
                        tools:ignore="ContentDescription" />
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="EMAIL"
                android:textColor="#C0BACA"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etEditEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input_orange"
                android:enabled="false"
                android:fontFamily="@font/quicksand_medium"
                android:paddingHorizontal="20dp"
                android:textColor="#C0BACA"
                android:textSize="15sp"
                tools:ignore="Autofill,SpeakableTextPresentCheck" />

            <!-- Input Nickname -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="BIỆT DANH"
                android:textColor="#C0BACA"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etEditNickname"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input_orange"
                android:fontFamily="@font/quicksand_medium"
                android:hint="Nhập biệt danh..."
                android:inputType="textPersonName"
                android:paddingHorizontal="20dp"
                android:textColor="#313866"
                android:textSize="15sp"
                tools:ignore="Autofill" />

            <!-- Input Motto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="CHÂM NGÔN"
                android:textColor="#C0BACA"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etEditBio"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input_teal"
                android:fontFamily="@font/quicksand_medium"
                android:gravity="top"
                android:hint="Chia sẻ về bạn..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#313866"
                android:textSize="14sp"
                tools:ignore="Autofill" />

            <!-- Mục tiêu cảm xúc -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="MỤC TIÊU CẢM XÚC"
                android:textColor="#C0BACA"
                android:textSize="11sp" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/flexGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:flexDirection="row"
                app:flexWrap="wrap"
                app:justifyContent="flex_start" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#F5F5F5" />

            <!-- Nút đổi mật khẩu -->
            <RelativeLayout
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/iconLock"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_light_purple_circle"
                    android:padding="10dp"
                    android:src="@drawable/ic_lock"
                    app:tint="#9575CD"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/iconLock"
                    android:fontFamily="@font/quicksand_bold"
                    android:text="Đổi mật khẩu"
                    android:textColor="#313866"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#C0BACA"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <!-- Nút Xóa tài khoản (Giấu trong dialog) -->
            <RelativeLayout
                android:id="@+id/layoutDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/iconDelete"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_light_red_circle"
                    android:padding="10dp"
                    android:src="@drawable/ic_delete"
                    app:tint="#FF6B6B"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/iconDelete"
                    android:fontFamily="@font/quicksand_bold"
                    android:text="Xóa tài khoản"
                    android:textColor="#FF6B6B"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#C0BACA"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="Lưu thay đổi"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="#00BFA5"
                app:cornerRadius="30dp"
                app:elevation="0dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.cardview.widget.CardView>