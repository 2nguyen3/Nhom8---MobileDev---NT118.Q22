<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_glass"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="30dp">

    <TextView
        android:id="@+id/tvFlowerEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="🌸"
        android:textSize="60sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/quicksand_bold"
        android:text="Tuyệt lắm!"
        android:textColor="#F48FB1"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/tvResultDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:fontFamily="@font/quicksand_medium"
        android:gravity="center"
        android:text="Bạn vừa hoàn thành 1 phút\n4 chu kỳ hít thở 💚"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRetry"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_btn_glass_pink"
        android:fontFamily="@font/quicksand_bold"
        android:text="🌸 Tuyệt vời! Thử lại?"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />
</LinearLayout>