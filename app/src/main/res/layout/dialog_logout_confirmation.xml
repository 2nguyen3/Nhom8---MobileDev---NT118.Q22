<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="30dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_light_pink_circle" />

            <TextView
                android:id="@+id/tvDialogAvatarEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌸"
                android:textSize="32sp" />
        </FrameLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/quicksand_medium"
            android:gravity="center"
            android:text="Bạn có chắc chắn muốn rời đi không?"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/quicksand_bold"
            android:text="Trở về"
            android:letterSpacing="0"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#E86FA0"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

        <TextView
            android:id="@+id/tvConfirmLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/quicksand_bold"
            android:padding="10dp"
            android:text="Đăng xuất"
            android:textColor="#C0BACA"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>