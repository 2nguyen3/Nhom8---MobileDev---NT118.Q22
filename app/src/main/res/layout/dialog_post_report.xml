<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="28dp"
    android:layout_marginEnd="28dp"
    android:background="@drawable/bg_dialog_report_post"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/txtReportTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Báo cáo bài viết"
        android:textColor="#3B2A58"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtReportSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="Hãy cho chúng tôi biết lý do bạn muốn báo cáo bài viết này."
        android:textColor="#8E7EA7"
        android:textSize="14sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/radioGroupReportReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioSpam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="#E8507A"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Spam hoặc quảng cáo"
            android:textColor="#5F5370"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/radioOffensive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="#E8507A"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Nội dung xúc phạm hoặc công kích"
            android:textColor="#5F5370"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/radioUnsafe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="#E8507A"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Nội dung gây hại / không an toàn"
            android:textColor="#5F5370"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioButton
            android:id="@+id/radioOther"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="#E8507A"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Lý do khác"
            android:textColor="#5F5370"
            android:textSize="13sp"
            android:textStyle="bold" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/layoutReportActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancelReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_report_dialog_cancel"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:text="Hủy"
            android:textColor="#9E90B1"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSubmitReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_report_dialog_submit"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:text="Gửi báo cáo"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>