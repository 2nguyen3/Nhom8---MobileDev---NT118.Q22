<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_permission_ombre"
    android:overScrollMode="never"
    android:scrollbars="none"
    tools:context=".activities.PermissionActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingBottom="60dp">

        <ImageView
            android:id="@+id/imgCloud"
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_cloud_happy"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BƯỚC 2 / 3"
            android:textColor="#FF8EB2"
            android:textSize="12sp"
            android:fontFamily="@font/quicksand_bold"
            app:layout_constraintTop_toBottomOf="@id/imgCloud"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Heami cần một vài quyền 🙏"
            android:textSize="24sp"
            android:textColor="#313866"
            android:gravity="center"
            android:fontFamily="@font/quicksand_bold"
            android:layout_marginHorizontal="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvStep"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvMainTitle">
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera 🤳"
                    android:textSize="18sp"
                    android:fontFamily="@font/quicksand_bold"
                    android:textColor="#313866"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Để Heami phân tích cảm xúc khuôn mặt qua AI Check-in."
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAllowCam"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="✓ Cho phép"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#FF4D8D"
                    app:cornerRadius="16dp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/quicksand_bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardNoti"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardCamera">
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông báo 🔔"
                    android:textSize="18sp"
                    android:fontFamily="@font/quicksand_bold"
                    android:textColor="#313866"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nhắc nhở check-in hàng ngày, nhắc uống nước."
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:id="@+id/layoutActionNoti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAllowNoti"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="54dp"
                        android:text="✓ Cho phép"
                        android:backgroundTint="#4DB6AC"
                        app:cornerRadius="16dp"
                        android:textAllCaps="false"/>
                    <Space android:layout_width="12dp" android:layout_height="wrap_content"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSkipNoti"
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:text="BỎ QUA"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#E0E0E0"
                        app:cornerRadius="16dp"
                        android:textColor="#A0A0A0"
                        android:textAllCaps="false"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvSkipNoteNoti"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã bỏ qua · Có thể bật lại trong Cài đặt"
                    android:textColor="#A0A0A0"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardNoti">
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vị trí 📍"
                    android:textSize="18sp"
                    android:fontFamily="@font/quicksand_bold"
                    android:textColor="#313866"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tuỳ chọn gợi ý theo thời tiết xung quanh."
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"/>
                <LinearLayout
                    android:id="@+id/layoutActionLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAllowLocation"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="54dp"
                        android:text="✓ Cho phép"
                        android:backgroundTint="#B197E2"
                        app:cornerRadius="16dp"
                        android:textAllCaps="false"/>
                    <Space android:layout_width="12dp" android:layout_height="wrap_content"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSkipLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:text="BỎ QUA"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#E0E0E0"
                        app:cornerRadius="16dp"
                        android:textColor="#A0A0A0"
                        android:textAllCaps="false"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvSkipNoteLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã bỏ qua · Có thể bật lại trong Cài đặt"
                    android:textColor="#A0A0A0"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvProgressStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/3 hoàn thành"
            android:textColor="#FF4D8D"
            android:fontFamily="@font/quicksand_bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/cardLocation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueSetup"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            android:text="Tiếp tục thiết lập hồ sơ ›"
            android:visibility="gone"
            android:backgroundTint="#FF4D8D"
            app:cornerRadius="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvProgressStatus"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="@font/quicksand_bold"/>

        <TextView
            android:id="@+id/btnSkipAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bỏ qua tất cả, thiết lập sau"
            android:textColor="#7A869A"
            android:textSize="16sp"
            android:fontFamily="@font/quicksand_bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnContinueSetup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>