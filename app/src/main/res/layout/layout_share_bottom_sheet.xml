<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="45dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#40FFFFFF" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvShareTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/quicksand_bold"
            android:text="🌸 Chia sẻ bài nhạc"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <ImageButton
            android:id="@+id/btnCloseShare"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="#80FFFFFF" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Gửi cho bạn bè để cùng thư giãn"
        android:textColor="#80FFFFFF"
        android:textSize="14sp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_share_music_card"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/imgThumb"
            android:layout_width="65dp"
            android:layout_height="65dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="32.5dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="15dp"
                android:src="@drawable/tape"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/imgThumb"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/quicksand_bold"
                android:text="Giai điệu thư giãn"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Nhạc trị liệu"
                android:textColor="#80FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_tag_heami"
            android:fontFamily="@font/quicksand_bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="HEAMI"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/bg_social_zalo"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_social_zalo"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/zalo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="Zalo"
                android:textColor="#4D94FF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bg_social_mess"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_social_mess"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/messenger" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="Messenger"
                android:textColor="#6081C4" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bg_social_insta"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_social_insta"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/instagram" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="Instagram"
                android:textColor="#E1306C" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bg_social_threads"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_social_threads"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/threads" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="Threads"
                android:textColor="#FFFF" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="100dp"
            android:layout_height="1dp"
            android:background="#26FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:text="hoặc"
            android:textColor="#40FFFFFF"
            android:textSize="12sp" />

        <View
            android:layout_width="100dp"
            android:layout_height="1dp"
            android:background="#26FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnCopyContent"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="25dp"
        android:background="@drawable/bg_copy_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/copy"
            app:tint="#B3FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/quicksand_bold"
            android:text="Sao chép nội dung"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>