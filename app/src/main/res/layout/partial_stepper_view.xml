<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- Step 1: Đặt lịch -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/step1_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/teal" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đặt lịch"
            android:textSize="10sp"
            android:textColor="#2D1B47"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <View
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="8dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="14dp"/>

    <!-- Step 2: Thanh toán -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:id="@+id/step2_number"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_light_teal_circle"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/teal_dark"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thanh toán"
            android:textSize="10sp"
            android:textColor="#2D1B47"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <View
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="8dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="14dp"/>

    <!-- Step 3: Hóa đơn -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:id="@+id/step3_number"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_light_gray_circle"
            android:gravity="center"
            android:text="3"
            android:textColor="#9E8AAA"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hóa đơn"
            android:textSize="10sp"
            android:textColor="#9E8AAA"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>