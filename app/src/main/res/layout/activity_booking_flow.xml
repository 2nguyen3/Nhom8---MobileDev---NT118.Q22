<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bookingFlowRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF9FB">

    <!-- Background blobs -->
    <View
        android:id="@+id/blobDoctorPink"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.2"
        android:background="@drawable/bg_blob_doctor_pink"
        android:translationX="-36dp"
        android:translationY="-48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/blobDoctorMint"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:alpha="0.1"
        android:background="@drawable/bg_blob_doctor_mint"
        android:translationX="36dp"
        android:translationY="470dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="50dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="15dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackFlow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_doctor_detail_round_btn"
            android:contentDescription="Quay lại"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/txtFlowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đặt lịch"
                android:textColor="#2D1B47"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtFlowSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="An toàn • Bảo mật • Nhanh chóng"
                android:textColor="#E8507A"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Stepper -->
    <LinearLayout
        android:id="@+id/layoutStepper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <include layout="@layout/partial_stepper_view" />
    </LinearLayout>

    <!-- Content -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/booking_nav_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="140dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutStepper" />

    <!-- Bottom Action (Glass container with Gradient Button) -->
    <LinearLayout
        android:id="@+id/layoutBottomAction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_doctor_detail_bottom_bar"
        android:elevation="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMainAction"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_confirm_gradient"
            android:elevation="8dp"
            android:stateListAnimator="@null"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>