<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#2A1F4D"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgSoundIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:src="@drawable/ic_lock"
            app:tint="#FFFFFF" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/cardIcon"
        android:layout_toStartOf="@id/imgCheck"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSoundTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mưa rơi thanh tịnh"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/quicksand_bold" />

        <TextView
            android:id="@+id/tvSoundSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Âm thanh thiên nhiên • Trị liệu"
            android:textColor="#80FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgCheck"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_check"
        app:tint="#00E5FF"
        android:visibility="gone" />

</RelativeLayout>