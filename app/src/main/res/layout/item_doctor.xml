<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardDoctor"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_doctor_card"
    android:elevation="8dp"
    android:orientation="horizontal"
    android:padding="14dp"
    android:translationZ="2dp">

    <FrameLayout
        android:id="@+id/layoutDoctorAvatar"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_doctor_avatar_pink">

        <ImageView
            android:id="@+id/imgDoctorAvatar"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_doctor_image_clip"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/img_doctor_1"
            android:contentDescription="doctor avatar" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDoctorName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tên bác sĩ"
                android:textColor="#2D1B47"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnDoctorBookmark"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_doctor_bookmark_btn"
                android:contentDescription="bookmark"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_doctor_bookmark"
                tools:ignore="TouchTargetSizeCheck" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:background="#E5E7EB" />

        <TextView
            android:id="@+id/txtDoctorSpecialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Chuyên môn"
            android:textColor="#FFB6D9"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Row 1: Location -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:src="@drawable/ic_doctor_location"
                android:contentDescription="location" />

            <TextView
                android:id="@+id/txtDoctorLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="Địa điểm"
                android:textColor="#9E8AAA"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2: Rating & Reviews -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:src="@drawable/ic_doctor_star"
                android:contentDescription="star" />

            <TextView
                android:id="@+id/txtDoctorRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="0.0"
                android:textColor="#2D1B47"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDoctorReviewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="(0 reviews)"
                android:textColor="#B0A0C0"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtDoctorPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0đ"
                    android:textColor="#2D1B47"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="/phiên"
                    android:textColor="#C0AEC8"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/badgeDoctorAvailable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_doctor_available_badge"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <View
                    android:id="@+id/dotDoctorAvailable"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_doctor_available_dot" />

                <TextView
                    android:id="@+id/txtDoctorOnlineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Online"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
