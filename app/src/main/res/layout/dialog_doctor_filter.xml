<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutFilterRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_doctor_filter_dialog"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bộ lọc &amp; Sắp xếp"
        android:textColor="#2D1B47"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:text="SẮP XẾP THEO"
        android:textColor="#B0A0C0"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <!-- List of options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Option: Online Status -->
        <LinearLayout
            android:id="@+id/layoutSortOnline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_doctor_filter_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <FrameLayout
                android:layout_width="20dp"
                android:layout_height="20dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_doctor_available_dot" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Đang trực tuyến"
                android:textColor="#2D1B47"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Option: Rating -->
        <LinearLayout
            android:id="@+id/layoutSortRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_doctor_filter_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_doctor_star" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Đánh giá cao nhất"
                android:textColor="#2D1B47"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Option: Price Low to High -->
        <LinearLayout
            android:id="@+id/layoutSortPriceLow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_doctor_filter_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="💸"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Giá thấp → cao"
                android:textColor="#2D1B47"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Option: Price High to Low -->
        <LinearLayout
            android:id="@+id/layoutSortPriceHigh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_doctor_filter_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="💎"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Giá cao → thấp"
                android:textColor="#2D1B47"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Option: Experience -->
        <LinearLayout
            android:id="@+id/layoutSortExp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_doctor_filter_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_doctor_experience" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Kinh nghiệm nhiều nhất"
                android:textColor="#2D1B47"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnApplyFilter"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#E86FA0"
        android:text="Áp dụng lọc"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

    <!-- Handle bar at bottom -->
    <FrameLayout
        android:id="@+id/handleBarContainer"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="4dp">

        <View
            android:id="@+id/viewHandleBar"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="#E5E7EB"
            android:backgroundTint="#D1D5DB" />
    </FrameLayout>

</LinearLayout>
