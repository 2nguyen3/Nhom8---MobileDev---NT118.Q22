<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F9F9"
    android:padding="24dp">

    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_white_rounded_button"
        android:fontFamily="@font/quicksand_bold"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:text="Bỏ qua"
        android:textColor="#313866"
        android:textSize="14sp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivOnboardingAi"
        android:layout_width="220dp"
        android:layout_height="200dp"
        android:layout_marginTop="100dp"
        android:src="@drawable/ic_cloud_ai"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTagAi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_btn_onboarding"
        android:backgroundTint="#E0F2F1"
        android:fontFamily="@font/quicksand_bold"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="AI CHECK-IN"
        android:textColor="#80CBC4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivOnboardingAi" />

    <TextView
        android:id="@+id/tvTitleAi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/quicksand_bold"
        android:gravity="center"
        android:text="Check-in cảm xúc\nbằng AI Camera"
        android:textColor="#313866"
        android:textSize="28sp"
        app:layout_constraintTop_toBottomOf="@id/tvTagAi" />

    <TextView
        android:id="@+id/tvDescriptionAi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/quicksand_medium"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingHorizontal="20dp"
        android:text="Chỉ cần nhìn vào camera, Heami sẽ cảm nhận và phân tích tâm trạng của bạn chính xác."
        android:textColor="#707070"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleAi" />

    <LinearLayout
        android:id="@+id/layout_indicators_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btnNextAi"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/bg_btn_onboarding"
            android:backgroundTint="#D1E8E8" />

        <View
            android:layout_width="24dp"
            android:layout_height="6dp"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/bg_btn_onboarding"
            android:backgroundTint="#80CBC4" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/bg_btn_onboarding"
            android:backgroundTint="#D1E8E8" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnNextAi"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_btn_onboarding"
        android:backgroundTint="#80CBC4"
        android:fontFamily="@font/quicksand_bold"
        android:gravity="center"
        android:text="Tiếp theo →"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackAi" />

    <ImageButton
        android:id="@+id/btnBackAi"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_white_rounded_button"
        android:contentDescription="Back Button"
        android:padding="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintBottom_toBottomOf="@id/btnNextAi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnNextAi"
        app:tint="#313866" />

</androidx.constraintlayout.widget.ConstraintLayout>