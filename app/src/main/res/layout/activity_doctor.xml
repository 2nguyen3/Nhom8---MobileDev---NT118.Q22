<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/doctorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_doctor_screen"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Background blobs -->
    <View
        android:id="@+id/blobDoctorPink"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.95"
        android:background="@drawable/bg_blob_doctor_pink"
        android:translationX="-36dp"
        android:translationY="-48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/blobDoctorMint"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:alpha="0.95"
        android:background="@drawable/bg_blob_doctor_mint"
        android:translationX="36dp"
        android:translationY="470dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main scroll -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDoctor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingTop="56dp"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutDoctorContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/layoutDoctorHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtDoctorHeaderLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="TƯ VẤN CHUYÊN SÂU"
                        android:textColor="#C4A8E8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDoctorHeaderTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bác sĩ tư vấn"
                        android:textColor="#2B1C45"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnDoctorOptions"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_back_btn_community"
                    android:contentDescription="Tuỳ chọn"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_doctor_menu" />
            </LinearLayout>

            <!-- Ready notice -->
            <LinearLayout
                android:id="@+id/layoutDoctorReadyNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_doctor_onl"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp">

                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_doctor_notice_icon_box">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_doctor_notice"
                        android:contentDescription="notice" />
                </FrameLayout>

                <TextView
                    android:id="@+id/txtDoctorReadyNotice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="5 chuyên gia đang trực tuyến"
                    android:textColor="#9E8AAA"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Search bar -->
            <LinearLayout
                android:id="@+id/layoutDoctorSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_doctor_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <ImageView
                    android:id="@+id/imgDoctorSearch"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_doctor_search"
                    android:contentDescription="search" />

                <EditText
                    android:id="@+id/edtDoctorSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Tìm bác sĩ, chuyên môn..."
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:padding="0dp"
                    android:textColor="#2D1B47"
                    android:textColorHint="#802D1B47"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnDoctorSearchClear"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="8dp"
                    android:alpha="0.4"
                    android:src="@drawable/ic_close"
                    app:tint="#2D1B47"
                    android:visibility="gone"
                    android:contentDescription="@string/clear_search" />
            </LinearLayout>

            <!-- Filter tabs -->
            <HorizontalScrollView
                android:id="@+id/scrollDoctorFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutDoctorFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/filterDoctorAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_doctor_filter_active"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="Tất cả"
                        android:textColor="#E86FA0"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterDoctorClinical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_doctor_filter"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="Lâm sàng"
                        android:textColor="#8A9AAA"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterDoctorPsychiatry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_doctor_filter"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="Tâm thần"
                        android:textColor="#8A9AAA"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterDoctorTherapy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_doctor_filter"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="Trị liệu"
                        android:textColor="#8A9AAA"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterDoctorPositive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_doctor_filter"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="Tích cực"
                        android:textColor="#8A9AAA"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterDoctorCare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_doctor_filter"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="Chăm sóc"
                        android:textColor="#8A9AAA"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Recycler View for Doctors -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDoctors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutDoctorEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="60dp"
                android:paddingBottom="40dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không tìm thấy bác sĩ nào phù hợp"
                    android:textColor="#2D1B47"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hãy thử tìm kiếm bằng từ khoá khác nhé"
                    android:textColor="#9E8AAA"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Error State -->
            <LinearLayout
                android:id="@+id/layoutDoctorErrorState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="60dp"
                android:paddingBottom="40dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã có lỗi xảy ra khi tải dữ liệu"
                    android:textColor="#2D1B47"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Vui lòng kiểm tra kết nối mạng và thử lại"
                    android:textColor="#9E8AAA"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnDoctorRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#F3E8FF"
                    android:text="Thử lại"
                    android:textColor="#E86FA0"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Load More Button -->
            <Button
                android:id="@+id/btnDoctorLoadMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:backgroundTint="#F3E8FF"
                android:text="Xem thêm bác sĩ"
                android:textColor="#E86FA0"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom nav -->
    <include
        android:id="@+id/includeBottomNav"
        layout="@layout/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
