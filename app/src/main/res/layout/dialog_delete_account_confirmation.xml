<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="30dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_light_red_circle" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_delete"
                app:tint="#FF6B6B" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/quicksand_bold"
            android:text="Xóa tài khoản vĩnh viễn?"
            android:textColor="#FF6B6B"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/quicksand_medium"
            android:gravity="center"
            android:text="Mọi dữ liệu cảm xúc và thông tin cá nhân của bạn sẽ bị xóa sạch khỏi hệ thống và không thể khôi phục."
            android:textColor="#7D8BB7"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelDelete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/quicksand_bold"
            android:text="Giữ lại tài khoản"
            android:letterSpacing="0"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#00BFA5"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

        <TextView
            android:id="@+id/tvConfirmDeleteAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/quicksand_bold"
            android:padding="10dp"
            android:text="Tôi hiểu, hãy xóa tài khoản"
            android:textColor="#FF6B6B"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>