<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#4DFF4F5B" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1.5dp"
                android:color="#FF4F5B" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#1AFF4F5B" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#4DFF4F5B" />
        </shape>
    </item>

</selector>