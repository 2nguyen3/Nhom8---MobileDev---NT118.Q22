<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- glow -->
    <item>
        <shape>
            <size android:width="96dp" android:height="96dp"/>
            <solid android:color="#33FFD54A"/>
            <corners android:radius="48dp"/>
        </shape>
    </item>

    <!-- inner ring -->
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape>
            <solid android:color="#66FFD54A"/>
            <corners android:radius="38dp"/>
        </shape>
    </item>

    <!-- white center -->
    <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
        <shape>
            <solid android:color="#FFFFFF"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

</layer-list>